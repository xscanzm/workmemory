{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkMemory",
  "version": "0.3.0",
  "identifier": "com.workmemory.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx vite --port 5173",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WorkMemory 今日记忆",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "visible": false,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#f5f7fa"
      },
      {
        "label": "mascot",
        "url": "index.html#/mascot",
        "width": 340,
        "height": 146,
        "decorations": false,
        "visible": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "fullscreen": false,
        "shadow": false,
        "focusable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https://api.openai.com; font-src 'self' data:",
      "devCsp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost ws://localhost:5173 http://localhost:5173 https://api.openai.com; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
